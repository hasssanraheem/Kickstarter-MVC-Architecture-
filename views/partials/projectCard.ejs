<div class="project-card">
  <a href="/projects/<%= project.slug %>">
    <img src="<%= project.image %>" alt="<%= project.title %>" class="project-card-img" />
  </a>
  <div class="project-card-body">
    <span class="badge"><%= project.category %></span>
    <h3><a href="/projects/<%= project.slug %>"><%= project.title %></a></h3>
    <p class="project-card-desc"><%= project.shortDescription %></p>

    <div class="progress-bar">
      <div class="progress-fill" style="width: <%= project.percentFunded %>%"></div>
    </div>

    <div class="project-card-stats">
      <span><strong>$<%= project.amountRaised.toLocaleString() %></strong> raised</span>
      <span><strong><%= project.percentFunded %>%</strong> funded</span>
      <span><strong><%= project.daysRemaining %></strong> days left</span>
    </div>

    <p class="project-card-creator">by <a href="/users/<%= project.creator._id %>"><%= project.creator.name %></a></p>
  </div>
</div>
