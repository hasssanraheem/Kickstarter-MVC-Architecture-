<div class="form-page">
  <h1>Start Your Project</h1>
  <form action="/projects" method="POST" enctype="multipart/form-data" class="project-form">

    <div class="form-group">
      <label>Project Title *</label>
      <input type="text" name="title" maxlength="120" required class="form-control" placeholder="What's your project called?" />
    </div>

    <div class="form-group">
      <label>Short Description * <small>(max 200 chars)</small></label>
      <input type="text" name="shortDescription" maxlength="200" required class="form-control" placeholder="One-line pitch for your project" />
    </div>

    <div class="form-group">
      <label>Full Description *</label>
      <textarea name="description" rows="8" required class="form-control" placeholder="Tell backers everything about your project..."></textarea>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label>Category *</label>
        <select name="category" required class="form-control">
          <option value="">Select category</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label>Funding Goal ($) *</label>
        <input type="number" name="fundingGoal" min="1" required class="form-control" placeholder="e.g. 5000" />
      </div>

      <div class="form-group">
        <label>Campaign Deadline *</label>
        <input type="date" name="deadline" required class="form-control" />
      </div>
    </div>

    <div class="form-group">
      <label>Project Image</label>
      <input type="file" name="image" accept="image/*" class="form-control" />
    </div>

    <div class="form-group">
      <label>Video URL (YouTube/Vimeo embed)</label>
      <input type="url" name="videoUrl" class="form-control" placeholder="https://www.youtube.com/embed/..." />
    </div>

    <div class="form-group">
      <label>Tags <small>(comma-separated)</small></label>
      <input type="text" name="tags" class="form-control" placeholder="e.g. tech, hardware, open-source" />
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-lg">Launch Project</button>
      <a href="/projects" class="btn btn-outline">Cancel</a>
    </div>
  </form>
</div>
